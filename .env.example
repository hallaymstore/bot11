# Required: BotFather token
BOT_TOKEN=123456789:AA_EXAMPLE_REPLACE_WITH_REAL_TOKEN

# Required for Telegram Mini App button. Must be HTTPS in production.
# Examples:
# WEBAPP_URL=https://your-domain.com
# WEBAPP_URL=https://your-ngrok-url.ngrok-free.app
WEBAPP_URL=https://your-domain.com

# Server port
PORT=3000

# Optional: production/development
NODE_ENV=production

# Optional: automatically set Telegram menu button to open Mini App
SET_MENU_BUTTON=true


# Optional: if the bot was previously set with webhook, delete it automatically before polling
AUTO_DELETE_WEBHOOK=true
DROP_PENDING_UPDATES=true

# Optional: text shown by the bot
BOT_TITLE=Crypto Clicker
