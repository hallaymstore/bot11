# Required: BotFather token
BOT_TOKEN=YOUR_BOTFATHER_TOKEN

# Required for Telegram Mini App button. Must be HTTPS for Telegram.
# Local Telegram test examples:
# WEBAPP_URL=https://your-ngrok-url.ngrok-free.app
# WEBAPP_URL=https://your-cloudflare-url.trycloudflare.com
WEBAPP_URL=https://your-domain.com

PORT=3000
NODE_ENV=production
DEV_MODE=false
SET_MENU_BUTTON=true
BOT_TITLE=Crypto Clicker Pro

# Polling helper: deletes active webhook before getUpdates polling
AUTO_DELETE_WEBHOOK=true
DROP_PENDING_UPDATES=true

# Admin panel: /admin.html
ADMIN_PASSWORD=change-this-password
# Optional: comma-separated Telegram user IDs that can be admin via Mini App initData
ADMIN_IDS=
